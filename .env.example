# Asana Personal Access Token (required)
# Generate one at: Asana > Settings > Apps > Developer > Personal Access Tokens
ASANA_TOKEN=

# Optional: enum custom field used to track progress on your board.
# When both are set, `asana-cli complete` sets this field instead of the
# completed checkbox (use --close to also check the task off).
# ASANA_PROGRESS_FIELD=Task Progress
# ASANA_PROGRESS_VALUE=Done
